#!/usr/bin/env bash
set -euo pipefail

# livery/bin/scaffold — Generate the Phase 2 project constitution
#
# Reads SPEC.md and ARCHITECTURE.md, generates:
#   - Workspace Cargo.toml and per-crate scaffolds
#   - CLAUDE.md (project constitution)
#   - scripts/validate.sh (with graduated quality thresholds)
#   - prism.toml
#   - standards/project.md
#   - skills/ directory
#   - SESSIONS.md
#   - .gitignore additions
#
# Usage:
#   livery/bin/scaffold              # run from project root
#   livery/bin/scaffold --dry-run    # show what would be created without writing

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIVERY_DIR="$(dirname "$SCRIPT_DIR")"
PROJECT_DIR="$(pwd)"
DRY_RUN=false

if [[ "${1:-}" == "--dry-run" ]]; then
    DRY_RUN=true
fi

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${GREEN}✓${NC} $1"; }
warn()  { echo -e "${YELLOW}⚠${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1"; }
header(){ echo -e "\n${BOLD}$1${NC}"; }

# --- Pre-flight checks ---

header "Scaffold — Phase 2 Setup"
echo ""

# Check we're in a git repo
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    error "Not in a git repository. Run this from your project root."
    exit 1
fi

# Check for SPEC.md
if [[ ! -f "SPEC.md" ]]; then
    error "SPEC.md not found."
    echo "  Write your SPEC.md first (Phase 0)."
    echo "  Use the write-spec skill: livery/skills/write-spec.md"
    exit 1
fi

# Check for ARCHITECTURE.md
if [[ ! -f "ARCHITECTURE.md" ]]; then
    error "ARCHITECTURE.md not found."
    echo "  Write your ARCHITECTURE.md first (Phase 1)."
    echo "  Use the write-architecture skill: livery/skills/write-architecture.md"
    exit 1
fi

# Install Livery submodule if not present
if [[ ! -f "livery/CLAUDE-base.md" ]]; then
    header "Installing Livery submodule..."
    if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] Would run: git submodule add https://github.com/jeffcwolf/livery livery"
    else
        if [[ -f ".gitmodules" ]] && grep -q "livery" .gitmodules 2>/dev/null; then
            git submodule update --init --recursive
        else
            git submodule add https://github.com/jeffcwolf/livery livery
            git submodule update --init --recursive
        fi
        info "Livery installed"
    fi
else
    info "Livery submodule present"
fi

info "SPEC.md found"
info "ARCHITECTURE.md found"

# --- Parse the crate map from ARCHITECTURE.md ---

header "Parsing crate map from ARCHITECTURE.md..."

# Extract crate map table rows (skip header and separator lines)
# Expected format: | crate-name | bin/lib | responsibility text |
CRATE_NAMES=()
CRATE_TYPES=()
CRATE_DESCS=()

IN_CRATE_MAP=false
while IFS= read -r line; do
    # Detect the start of the crate map table
    if [[ "$line" =~ ^##[[:space:]]+Crate[[:space:]]+Map ]]; then
        IN_CRATE_MAP=true
        continue
    fi

    # Stop at the next heading
    if [[ "$IN_CRATE_MAP" == true && "$line" =~ ^## && ! "$line" =~ ^##[[:space:]]+Crate[[:space:]]+Map ]]; then
        IN_CRATE_MAP=false
        continue
    fi

    # Skip non-table lines, header row, and separator row
    if [[ "$IN_CRATE_MAP" == true && "$line" =~ ^\| ]]; then
        # Skip the header row (contains "Crate")
        if [[ "$line" =~ \|[[:space:]]*Crate[[:space:]]*\| ]]; then
            continue
        fi
        # Skip separator row (contains ---)
        if [[ "$line" =~ \|[[:space:]]*-+ ]]; then
            continue
        fi

        # Parse: | name | type | description |
        crate_name=$(echo "$line" | awk -F'|' '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2); print $2}')
        crate_type=$(echo "$line" | awk -F'|' '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $3); print $3}')
        crate_desc=$(echo "$line" | awk -F'|' '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $4); print $4}')

        if [[ -n "$crate_name" && -n "$crate_type" ]]; then
            CRATE_NAMES+=("$crate_name")
            CRATE_TYPES+=("$crate_type")
            CRATE_DESCS+=("$crate_desc")
        fi
    fi
done < ARCHITECTURE.md

if [[ ${#CRATE_NAMES[@]} -eq 0 ]]; then
    error "No crates found in ARCHITECTURE.md."
    echo "  The Crate Map table must use this exact format:"
    echo ""
    echo "  ## Crate Map"
    echo ""
    echo "  | Crate | Type | Responsibility |"
    echo "  |---|---|---|"
    echo "  | myproject-cli | bin | CLI dispatch |"
    echo "  | myproject-core | lib | Core logic |"
    exit 1
fi

echo "  Found ${#CRATE_NAMES[@]} crate(s):"
for i in "${!CRATE_NAMES[@]}"; do
    echo "    ${CRATE_TYPES[$i]}  ${CRATE_NAMES[$i]} — ${CRATE_DESCS[$i]}"
done

# Infer project name from the bin crate (strip -cli suffix) or repo dir
PROJECT_NAME=""
BIN_CRATE=""
for i in "${!CRATE_NAMES[@]}"; do
    if [[ "${CRATE_TYPES[$i]}" == "bin" ]]; then
        BIN_CRATE="${CRATE_NAMES[$i]}"
        PROJECT_NAME="${BIN_CRATE%-cli}"
        break
    fi
done

if [[ -z "$PROJECT_NAME" ]]; then
    PROJECT_NAME=$(basename "$PROJECT_DIR")
    warn "No bin crate found. Using directory name: $PROJECT_NAME"
fi

# --- Helper: write a file (respects --dry-run, skips existing) ---

write_file() {
    local filepath="$1"
    local content="$2"
    local description="${3:-}"

    if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] Would create: $filepath"
        return
    fi

    if [[ -f "$filepath" ]]; then
        warn "Skipping $filepath (already exists)"
        return
    fi

    mkdir -p "$(dirname "$filepath")"
    echo "$content" > "$filepath"
    info "Created $filepath${description:+ — $description}"
}

# --- Generate workspace Cargo.toml ---

header "Generating workspace..."

# Build members list
MEMBERS=""
for name in "${CRATE_NAMES[@]}"; do
    MEMBERS+="    \"crates/${name}\","$'\n'
done

# Build workspace dependencies (lib crates only)
WORKSPACE_DEPS=""
for i in "${!CRATE_NAMES[@]}"; do
    if [[ "${CRATE_TYPES[$i]}" == "lib" ]]; then
        WORKSPACE_DEPS+="${CRATE_NAMES[$i]} = { path = \"crates/${CRATE_NAMES[$i]}\" }"$'\n'
    fi
done

CARGO_ROOT="[workspace]
members = [
${MEMBERS}]
resolver = \"2\"

[workspace.dependencies]
${WORKSPACE_DEPS}anyhow = \"1\"
thiserror = \"2\"
clap = { version = \"4\", features = [\"derive\"] }
serde = { version = \"1\", features = [\"derive\"] }
serde_json = \"1\"

[workspace.lints.clippy]
all = \"warn\""

# Handle existing non-workspace Cargo.toml (e.g., from cargo init/new)
if [[ -f "Cargo.toml" ]] && ! grep -q '\[workspace\]' Cargo.toml; then
    if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] Would replace non-workspace Cargo.toml with workspace"
    else
        warn "Cargo.toml exists but is not a workspace."
        echo "  Scaffold needs a workspace Cargo.toml. Replace it? (y/n)"
        read -r answer
        if [[ "$answer" == "y" || "$answer" == "Y" ]]; then
            mv Cargo.toml Cargo.toml.bak
            info "Backed up existing Cargo.toml to Cargo.toml.bak"
            echo "$CARGO_ROOT" > Cargo.toml
            info "Created Cargo.toml — workspace root"
        else
            error "Cannot proceed without a workspace Cargo.toml. Aborting."
            exit 1
        fi
    fi
else
    write_file "Cargo.toml" "$CARGO_ROOT" "workspace root"
fi

# Clean up orphan src/main.rs from cargo init/new
if [[ -f "src/main.rs" ]]; then
    if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] Would move orphan src/main.rs to src/main.rs.bak"
    else
        mv src/main.rs src/main.rs.bak
        info "Moved orphan src/main.rs to src/main.rs.bak (binary is in crates/)"
    fi
fi

# --- Generate per-crate scaffolds ---

for i in "${!CRATE_NAMES[@]}"; do
    name="${CRATE_NAMES[$i]}"
    type="${CRATE_TYPES[$i]}"
    desc="${CRATE_DESCS[$i]}"
    crate_dir="crates/${name}"

    if [[ "$type" == "bin" ]]; then
        # Binary crate
        CRATE_TOML="[package]
name = \"${name}\"
version = \"0.1.0\"
edition = \"2024\"

[[bin]]
name = \"${PROJECT_NAME}\"
path = \"src/main.rs\"

[dependencies]"

        # Add all lib crates as dependencies
        for j in "${!CRATE_NAMES[@]}"; do
            if [[ "${CRATE_TYPES[$j]}" == "lib" ]]; then
                CRATE_TOML+=$'\n'"${CRATE_NAMES[$j]} = { workspace = true }"
            fi
        done

        CRATE_TOML+="
anyhow = { workspace = true }
clap = { workspace = true }

[dev-dependencies]
assert_cmd = \"2\"
predicates = \"3\""

        MAIN_RS="use anyhow::Result;
use clap::Parser;

/// ${PROJECT_NAME} — ${desc}
#[derive(Parser)]
#[command(name = \"${PROJECT_NAME}\", version, about)]
struct Cli {
    // subcommands will be added here
}

fn main() -> Result<()> {
    let _cli = Cli::parse();
    println!(\"${PROJECT_NAME}: not yet implemented\");
    Ok(())
}"

        write_file "${crate_dir}/Cargo.toml" "$CRATE_TOML"
        write_file "${crate_dir}/src/main.rs" "$MAIN_RS"

    else
        # Library crate
        CRATE_TOML="[package]
name = \"${name}\"
version = \"0.1.0\"
edition = \"2024\"

[dependencies]
thiserror = { workspace = true }
serde = { workspace = true }
serde_json = { workspace = true }

[dev-dependencies]"

        # Derive a PascalCase error type name from crate name
        error_name=$(echo "$name" | sed 's/-/_/g' | awk -F'_' '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) substr($i,2)}1' OFS='')
        error_name="${error_name}Error"

        LIB_RS="//! ${desc}
//!
//! See \`ARCHITECTURE.md\` for the module design and public API contract.

/// Errors produced by this crate.
#[derive(Debug, thiserror::Error)]
pub enum ${error_name} {
    // Variants added as tests demand them.
}"

        write_file "${crate_dir}/Cargo.toml" "$CRATE_TOML"
        write_file "${crate_dir}/src/lib.rs" "$LIB_RS"
    fi
done

# --- Extract constraints from SPEC.md ---

CONSTRAINTS=""
IN_CONSTRAINTS=false
while IFS= read -r line; do
    if [[ "$line" =~ ^##.*Non-Negotiable[[:space:]]+Constraints ]]; then
        IN_CONSTRAINTS=true
        continue
    fi
    if [[ "$IN_CONSTRAINTS" == true && "$line" =~ ^## && ! "$line" =~ Non-Negotiable ]]; then
        break
    fi
    if [[ "$IN_CONSTRAINTS" == true && "$line" =~ ^[0-9]+\. ]]; then
        constraint=$(echo "$line" | sed 's/^[0-9]*\.[[:space:]]*//' | sed 's/\*\*//g' | sed 's/\.$//')
        CONSTRAINTS+="- ${constraint}"$'\n'
    fi
done < SPEC.md

# --- Generate CLAUDE.md ---

header "Generating CLAUDE.md..."

CRATE_RESP=""
for i in "${!CRATE_NAMES[@]}"; do
    CRATE_RESP+="- \`${CRATE_NAMES[$i]}\` — ${CRATE_DESCS[$i]}"$'\n'
done

CLAUDE_MD="# CLAUDE.md — ${PROJECT_NAME}

## MANDATORY PRE-FLIGHT (do this before ANY other action)

1. Run \`git submodule update --init --recursive\` to ensure \`livery/\`
   is populated. If the directory is empty, do NOT proceed.
2. Read \`livery/CLAUDE-base.md\` in full. It is the base constitution.
3. Read \`SPEC.md\` for what this project does and does not do.
4. Read \`ARCHITECTURE.md\` for the crate structure and boundaries.
5. Read the last 2–3 entries of \`SESSIONS.md\` (if it exists).

> **Extends:** \`livery/CLAUDE-base.md\` — that file governs design
> philosophy, TDD workflow, quality gates, and coding standards. This
> file adds project-specific rules. Where the two conflict, this file
> wins.

---

## HARD RULES (these override all other instincts — violation = session invalid)

**1. TDD is literal, not conceptual.**
Write a failing test. Run it. Watch it fail. Confirm it fails for the
right reason (missing functionality, not a compile error). Only then
write the minimum implementation to pass. Run the test. Watch it pass.
Never write implementation before a failing test exists. Never.

**2. Three-pass refactor is mandatory after every green.**
After tests pass, complete all three passes before committing:
- *Pass 1 — Ousterhout:* Load \`livery/standards/ousterhout.md\`. Run the
  Design Process Checklist. Fix every Red Flag.
- *Pass 2 — ARC names:* Load \`livery/standards/readable-code.md\` Part I.
  Misunderstanding test on every new name. Replace every placeholder.
- *Pass 3 — ARC expression:* Load \`livery/standards/readable-code.md\`
  Parts II–IV. Strip restating comments. Add decision comments.
  Guard clauses. One function, one thing.
Write findings to \`REFACTOR-EVIDENCE.md\` (checked by \`livery/bin/refactor-check\`).

**3. No \`.unwrap()\` in library code without \`// SAFETY:\` comment.**
Use \`.expect(\"reason\")\` or return \`Result\`. In tests, \`.unwrap()\` is fine.
Checked by \`livery/bin/lint-rules\`.

**4. No \`assert!(result.is_ok())\` or \`assert!(result.is_err())\`.**
Unwrap or pattern-match so failures are informative. Weak assertions hide
the actual error. Checked by \`livery/bin/lint-rules\`.

**5. No \`#[allow(dead_code)]\` in non-test code.**
Investigate the caller chain. If genuinely unused, remove the item.
If used, fix the visibility. Suppressing the warning masks wiring errors.
Checked by \`livery/bin/lint-rules\`.

**6. Every \`pub\` item has a doc comment. No exceptions.**
Checked by \`RUSTDOCFLAGS=\"-D missing_docs\" cargo doc --no-deps\` in
\`livery/bin/lint-rules\`.

**7. Scope is frozen at session start.**
If it is not listed in the session scope, do not touch it. Adjacent
improvements are scope creep. Record them in SESSIONS.md for a future
session.

**8. Commit messages follow the structured format.**
Type prefix, SESSION, WHY, WHAT, TRAPS fields. Single-line messages
are not acceptable. Checked by \`livery/bin/commit-check\`.

**9. Session does not close until all gates pass.**
Run \`scripts/validate.sh\` and confirm exit 0. No \"mostly passing.\"
No \"I'll fix this next session.\" Green or not done.

---

### Commit Message Format

Every commit must use this format:

\`\`\`
<type>: <what changed>

SESSION: <N>
WHY: <why this change was made — the motivation, not the mechanics>
WHAT:
- <specific change 1>
- <specific change 2>
TRAPS: <anything surprising, gotchas, or things that broke and were fixed>
DEPENDS: <what this change assumes or relies on>
\`\`\`

Types: \`feat:\`, \`fix:\`, \`refactor:\`, \`test:\`, \`docs:\`, \`style:\`, \`chore:\`

Rules:
- Commit after each discrete, compiling change.
- Never commit code that does not compile or has failing tests.
- Single-line commit messages like \"implement feature X\" are NOT acceptable.
- TRAPS is the most important field — if you hit a problem and solved it, say so.
- WHAT should name files changed and decisions made, 2–5 lines.
- Omit TRAPS or DEPENDS only if genuinely not applicable.
- PR descriptions use the same format.

---

## Reference Documents

| Document | Path |
|---|---|
| Base constitution | \`livery/CLAUDE-base.md\` |
| Design standards | \`livery/standards/ousterhout.md\` |
| Readability standards | \`livery/standards/readable-code.md\` |
| Rust standards | \`livery/standards/rust-specifics.md\` |
| Specification | \`SPEC.md\` |
| Architecture | \`ARCHITECTURE.md\` |
| Session log | \`SESSIONS.md\` |

---

## Crate Responsibilities

${CRATE_RESP}
---

## Project-Specific Constraints

${CONSTRAINTS}
---

## Session Contract Commands

Every session ends by running these in order:

\`\`\`bash
cargo test --workspace
cargo fmt --check
cargo clippy --workspace -- -D warnings
scripts/validate.sh
\`\`\`

---

## Project-Specific Anti-Patterns

<!-- Add as they emerge during development -->

---

## Key Types

<!-- Add after Phase 3 sessions establish the core types -->"

write_file "CLAUDE.md" "$CLAUDE_MD" "project constitution"

# --- Generate scripts/validate.sh (with graduated thresholds) ---

header "Generating validation pipeline..."

VALIDATE_SH='#!/usr/bin/env bash
set -euo pipefail

# validate.sh — Session validation pipeline
#
# Runs all quality gates. Exit non-zero = session incomplete.
# Generated by livery/bin/scaffold. Extend per project.

echo "=== Validation Pipeline ==="

# --- Gate 1: Formatting ---
echo ""
echo "--- Gate 1: cargo fmt ---"
cargo fmt --check

# --- Gate 2: Linting ---
echo ""
echo "--- Gate 2: cargo clippy ---"
cargo clippy --workspace -- -D warnings

# --- Gate 3: Tests ---
echo ""
echo "--- Gate 3: cargo test ---"
cargo test --workspace

# --- Gate 4: Doc coverage ---
echo ""
echo "--- Gate 4: Doc comments on pub items ---"
RUSTDOCFLAGS="-D missing_docs" cargo doc --no-deps --quiet 2>/dev/null || {
    echo "WARNING: Missing doc comments on pub items."
    echo "Run: RUSTDOCFLAGS=\"-D missing_docs\" cargo doc --no-deps"
    # Non-blocking during early development; becomes blocking at 500+ LOC
    LOC=$(find crates -name '\''*.rs'\'' -not -path '\''*/tests/*'\'' -exec cat {} + 2>/dev/null | wc -l | tr -d '\'' '\'')
    if [ "$LOC" -gt 500 ]; then
        echo "FAIL: Project has $LOC lines — doc coverage is mandatory."
        exit 1
    else
        echo "(non-blocking: project has only $LOC lines)"
    fi
}

# --- Gate 5: Livery lint rules ---
echo ""
echo "--- Gate 5: Livery lint rules ---"
if [[ -x "livery/bin/lint-rules" ]]; then
    livery/bin/lint-rules
else
    echo "WARNING: livery/bin/lint-rules not found or not executable."
fi

# --- Gate 6: Prism quality gate (graduated thresholds) ---
echo ""
echo "--- Gate 6: Prism quality gate ---"
if [[ -x "livery/bin/prism" ]]; then
    LOC=$(find crates -name '\''*.rs'\'' -not -path '\''*/tests/*'\'' -exec cat {} + 2>/dev/null | wc -l | tr -d '\'' '\'')

    if [ "$LOC" -lt 200 ]; then
        echo "  (early project: $LOC LOC — Prism runs in lenient mode)"
        cat > /tmp/prism-graduated.toml << '\''TOML'\''
[quality]
min_doc_coverage = 0
max_cyclomatic = 25
max_cognitive = 40
max_fn_lines_warn = 150
max_fn_lines_fail = 300
[testing]
min_test_ratio = 0.5
require_integration_tests = false
[safety]
max_unsafe_blocks = 0
TOML
        livery/bin/prism check . --config /tmp/prism-graduated.toml --no-deps --no-coverage
    elif [ "$LOC" -lt 2000 ]; then
        echo "  (growing project: $LOC LOC — raised thresholds)"
        cat > /tmp/prism-graduated.toml << '\''TOML'\''
[quality]
min_doc_coverage = 60
max_cyclomatic = 20
max_cognitive = 30
max_fn_lines_warn = 100
max_fn_lines_fail = 200
[testing]
min_test_ratio = 1.0
require_integration_tests = false
[safety]
max_unsafe_blocks = 0
TOML
        livery/bin/prism check . --config /tmp/prism-graduated.toml --no-deps --no-coverage
    else
        echo "  (production: $LOC LOC — full thresholds)"
        livery/bin/prism check . --strict --no-deps --no-coverage
    fi
else
    echo "WARNING: livery/bin/prism not executable. Run prism check manually."
fi

# --- Gate 7: TDD audit ---
echo ""
echo "--- Gate 7: TDD audit ---"
if [[ -x "livery/bin/tdd-audit" ]]; then
    livery/bin/tdd-audit || {
        EXIT_CODE=$?
        if [[ "$EXIT_CODE" -eq 2 ]]; then
            echo "FAIL: TDD audit failed. Most commits lack test evidence."
            exit 1
        fi
        # Exit code 1 = warning, non-blocking
        echo "(TDD audit passed with warnings)"
    }
else
    echo "WARNING: livery/bin/tdd-audit not found or not executable."
fi

# --- Gate 8: Refactor evidence ---
echo ""
echo "--- Gate 8: Refactor evidence ---"
if [[ -x "livery/bin/refactor-check" ]]; then
    livery/bin/refactor-check || {
        EXIT_CODE=$?
        if [[ "$EXIT_CODE" -eq 2 ]]; then
            echo "FAIL: REFACTOR-EVIDENCE.md not found."
            echo "Document the three refactoring passes before closing the session."
            exit 1
        fi
        # Exit code 1 = warning (incomplete but present)
        echo "(Refactor evidence present but incomplete — review manually)"
    }
else
    echo "WARNING: livery/bin/refactor-check not found or not executable."
fi

# --- Gate 9: Commit message format ---
echo ""
echo "--- Gate 9: Commit message format ---"
if [[ -x "livery/bin/commit-check" ]]; then
    livery/bin/commit-check || {
        EXIT_CODE=$?
        if [[ "$EXIT_CODE" -eq 2 ]]; then
            echo "FAIL: Majority of commits violate message format."
            exit 1
        fi
        echo "(Commit format check passed with warnings)"
    }
else
    echo "WARNING: livery/bin/commit-check not found or not executable."
fi

echo ""
echo "=== All gates passed ==="'

write_file "scripts/validate.sh" "$VALIDATE_SH" "validation pipeline (graduated thresholds)"

if [[ "$DRY_RUN" != true && -f "scripts/validate.sh" ]]; then
    chmod +x scripts/validate.sh
fi

# --- Generate prism.toml ---

header "Generating quality configuration..."

PRISM_TOML='# Production quality thresholds — the definition of done.
# During early development, scripts/validate.sh uses graduated
# thresholds based on codebase size. These are the targets.

[quality]
min_doc_coverage = 80
max_cyclomatic = 20
max_cognitive = 30
max_fn_lines_warn = 100
max_fn_lines_fail = 200

[testing]
min_test_ratio = 2.0
require_integration_tests = true

[safety]
max_unsafe_blocks = 0'

write_file "prism.toml" "$PRISM_TOML" "quality thresholds (production targets)"

# --- Generate standards/project.md ---

header "Generating project standards..."

if [[ -f "livery/standards/project.md.template" ]]; then
    if [[ "$DRY_RUN" != true && ! -f "standards/project.md" ]]; then
        mkdir -p standards
        cp livery/standards/project.md.template standards/project.md
        info "Created standards/project.md — from template"
    elif [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] Would create: standards/project.md"
    else
        warn "Skipping standards/project.md (already exists)"
    fi
else
    PROJECT_MD='# project.md — Project-Specific Standards

> **Status: optional.** Add project conventions below as they emerge.
> These override all other standards files.

---

<!-- Add project conventions below this line -->'

    write_file "standards/project.md" "$PROJECT_MD"
fi

# --- Create skills directory ---

if [[ "$DRY_RUN" != true ]]; then
    mkdir -p skills
    info "Created skills/ directory"
else
    echo "  [dry-run] Would create: skills/"
fi

# --- Generate SESSIONS.md ---

SESSIONS_MD="# SESSIONS.md — ${PROJECT_NAME}

> Session log. Each entry records scope, decisions, files changed,
> Prism baseline deltas, and deferred items.

---"

write_file "SESSIONS.md" "$SESSIONS_MD" "session log"

# --- Update .gitignore ---

header "Updating .gitignore..."

GITIGNORE_ENTRIES="/target/
**/*.rs.bk
Cargo.lock
.prism/
.orb/
.DS_Store
*.swp
*.swo
*~"

if [[ "$DRY_RUN" == true ]]; then
    echo "  [dry-run] Would update .gitignore"
elif [[ -f ".gitignore" ]]; then
    while IFS= read -r entry; do
        if [[ -n "$entry" ]] && ! grep -qxF "$entry" .gitignore 2>/dev/null; then
            echo "$entry" >> .gitignore
        fi
    done <<< "$GITIGNORE_ENTRIES"
    info "Updated .gitignore"
else
    echo "$GITIGNORE_ENTRIES" > .gitignore
    info "Created .gitignore"
fi

# --- Verify the scaffold compiles ---

header "Verifying workspace..."

if [[ "$DRY_RUN" == true ]]; then
    echo "  [dry-run] Would run: cargo check --workspace"
else
    if cargo check --workspace 2>/dev/null; then
        info "cargo check --workspace passed"
    else
        warn "cargo check failed — review the generated Cargo.toml files"
        echo "  This usually means a dependency or edition issue."
        echo "  Fix the errors, then run: cargo check --workspace"
    fi
fi

# --- Summary ---

header "Phase 2 complete!"
echo ""
echo "  Generated files:"
echo "    CLAUDE.md              Project constitution"
echo "    Cargo.toml             Workspace root"
for name in "${CRATE_NAMES[@]}"; do
    echo "    crates/${name}/     Crate scaffold"
done
echo "    scripts/validate.sh    Validation pipeline (graduated thresholds)"
echo "    prism.toml             Quality thresholds (production targets)"
echo "    standards/project.md   Project conventions (empty)"
echo "    skills/                Project skills directory"
echo "    SESSIONS.md            Session log"
echo ""
echo "  Next steps:"
echo "    1. Review CLAUDE.md — confirm the crate responsibilities and"
echo "       constraints are accurate"
echo "    2. Run: cargo check --workspace"
echo "    3. Commit: git add . && git commit -m 'Phase 2: Project constitution'"
echo "    4. Push: git push"
echo "    5. Open a Claude Code session and start Phase 3"
echo ""
echo "  New enforcement gates:"
echo "    livery/bin/tdd-audit       Verify test-before-impl in git history"
echo "    livery/bin/lint-rules      Livery-specific anti-pattern checks"
echo "    livery/bin/refactor-check  Verify three-pass refactoring evidence"
echo "    livery/bin/commit-check    Verify structured commit messages"
echo ""
echo "  Your first session prompt template is in livery/QUICKSTART.md"
